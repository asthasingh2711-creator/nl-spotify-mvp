# Optional — enables real LLM intent parsing & explanations
# Without this, the app runs in demo mode with heuristic parsing
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Spotify Web API (Client Credentials — server-side only, never exposed to browser)
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
