# Gemini — free-tier LLM for AI Mode query planning (recommended)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional OpenAI fallback (only used if GEMINI_API_KEY is not set)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_QUERY_MODEL=ft:gpt-4o-mini:your-org:spotify-planner:abc123

# Set to 1 to append prompt/plan pairs to data/training-log.jsonl for fine-tuning
# LOG_AI_QUERIES=1

# Spotify Web API (Client Credentials — server-side only, never exposed to browser)
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
