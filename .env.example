# Optional — enables LLM query planning for AI Mode (recommended)
# Without this, AI Mode uses heuristic search query generation
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional — override model for Spotify query planner (use your fine-tuned model ID here)
# OPENAI_QUERY_MODEL=ft:gpt-4o-mini:your-org:spotify-planner:abc123
# Set to 1 to append prompt/plan pairs to data/training-log.jsonl for fine-tuning
# LOG_AI_QUERIES=1

# Spotify Web API (Client Credentials — server-side only, never exposed to browser)
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
